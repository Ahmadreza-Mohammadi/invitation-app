# ═══════════════════════════════════════════════════════════
#  ۱) این فایل را کپی کن:  cp .env.example .env
#  ۲) مقادیر زیر را در .env پر کن
#  ۳) npm run dev
# ═══════════════════════════════════════════════════════════

# ── آدرس پروژه (الزامی) ───────────────────────────────────
# Supabase → Project Settings → API → Project URL
# فقط همین — بدون /rest/v1/
SUPABASE_URL=https://ynzouvvlfzvxdcqyxdju.supabase.co

# ── کلید API (یکی از این‌ها را پر کن) ─────────────────────
#
# ★ پیشنهادی برای سرور Express:
# Supabase → Settings → API → API Keys → secret
SUPABASE_SECRET_KEY=

# جایگزین (publishable — اگر secret نداری):
# SUPABASE_PUBLISHABLE_KEY=

# جایگزین (Legacy — اگر publishable کار نکرد):
# Supabase → Settings → API → Legacy API keys → anon
# SUPABASE_ANON_KEY=

# ── سرور لوکال (همین‌ها را نگه دار) ───────────────────────
PORT=3001
VITE_API_URL=/api
